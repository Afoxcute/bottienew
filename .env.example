# Magic (embedded wallet)
NEXT_PUBLIC_MAGIC_API_KEY=

# Magic (server-side only — NEVER prefix with NEXT_PUBLIC_)
MAGIC_SECRET_KEY=

# App session signing (server-side only)
SESSION_JWT_SECRET=

# ZeroDev (Base smart-account execution)
NEXT_PUBLIC_ZERODEV_RPC_URL=
NEXT_PUBLIC_ZERODEV_PAYMASTER_RPC_URL=

# Particle Universal Account (cross-chain conversion)
NEXT_PUBLIC_PARTICLE_PROJECT_ID=
NEXT_PUBLIC_PARTICLE_CLIENT_KEY=
NEXT_PUBLIC_PARTICLE_APP_ID=

# Alchemy RPC
NEXT_PUBLIC_ALCHEMY_API_KEY=

# YO Protocol (optional — partner attribution)
NEXT_PUBLIC_YO_PARTNER_ID=

# MoonPay (server-side only)
MOONPAY_API_KEY=
MOONPAY_SECRET_KEY=

# MoonPay widget (client-side publishable key)
NEXT_PUBLIC_MOONPAY_API_KEY=

# Openfort (server-side only — NEVER prefix with NEXT_PUBLIC_)
# Get these from https://dashboard.openfort.io
OPENFORT_SECRET_KEY=
OPENFORT_WALLET_SECRET=
# ID of your backend wallet (acc_* format) — create one in the Openfort dashboard
OPENFORT_BACKEND_WALLET_ID=

# x402 — address that receives micro-payments for premium API access
# Must be a Base Sepolia address (x402 payments run on eip155:84532 testnet;
# the public x402.org facilitator only supports testnets)
X402_PAYTO_ADDRESS=
# Optional: override the default facilitator (defaults to https://x402.org/facilitator)
# X402_FACILITATOR_URL=

# App base URL — used by AI tools to call their own x402-protected endpoints
# Set to your Vercel deployment URL in production (e.g. https://bottie.xyz)
# Localhost is used automatically in development
NEXT_PUBLIC_APP_URL=

# AI (server-side only)
OPENAI_API_KEY=
